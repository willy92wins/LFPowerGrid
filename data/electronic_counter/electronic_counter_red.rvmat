forcedDiffuse[] = {0.65, 0.05, 0.05, 1};
emmisive[]      = {60, 8, 8, 1};
specular[]      = {0.45, 0.05, 0.05, 1};
specularPower   = 20;
PixelShaderID   = "Normal";
VertexShaderID  = "Basic";
