// =========================================================
// LF_PowerGrid — Sorter Tag Chip prefab (Dabs MVC)
// Used as item in ObservableCollection<ref LFPG_SorterTagView>
// Renders inside WrapSpacerWidget "TagsList" (295px wide)
//
// FIX L2: All children now use pixel positioning (hexactpos/size 1).
// Eliminates fragile pixel/proportional mix that could cause
// text-button overlap at extreme resolutions. UIScaler handles
// resolution adaptation uniformly post-creation.
// =========================================================
FrameWidgetClass TagRoot {
	size 1 28
	hexactpos 0
	vexactpos 0
	hexactsize 0
	vexactsize 1
	clipchildren 1
	{
		ImageWidgetClass TagBg {
			position 0 0
			size 1 1
			hexactpos 0
			vexactpos 0
			hexactsize 0
			vexactsize 0
			stretch 1
			ignorepointer 1
			{
			}
		}
		TextWidgetClass TagLabel {
			scriptclass "ViewBinding"
			position 8 0
			size 250 28
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/Metron"
			"text valign" center
			ignorepointer 1
			{
				ScriptParamsClass {
					Binding_Name "TagLabel"
					{
					}
				}
			}
		}
		ButtonWidgetClass BtnRemove {
			position 265 4
			size 18 20
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			{
				TextWidgetClass BtnRemoveText {
					position 0 0
					size 1 1
					hexactpos 0
					vexactpos 0
					hexactsize 0
					vexactsize 0
					font "gui/fonts/Metron"
					"text halign" center
					"text valign" center
					text "x"
					ignorepointer 1
					{
					}
				}
			}
		}
	}
}
