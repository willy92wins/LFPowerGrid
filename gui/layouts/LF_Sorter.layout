							vexactpos 1
							hexactsize 1
							vexactsize 1
							stretch 1
							ignorepointer 1
						}

						TextWidgetClass HeaderTitle {
							scriptclass "ViewBinding"
							position 14 9
							size 200 24
							hexactpos 1
							vexactpos 1
							hexactsize 1
							vexactsize 1
							font "gui/fonts/Metron"
							ignorepointer 1
						}

						TextWidgetClass StatusLabel {
							position 520 12
							size 80 18
							hexactpos 1
							vexactpos 1
							hexactsize 1
							vexactsize 1
							font "gui/fonts/MetronBook"
							"text halign" right
							ignorepointer 1
