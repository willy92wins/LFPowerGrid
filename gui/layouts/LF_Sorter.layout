// =========================================================
// LF_PowerGrid — Sorter UI v2.0 (Dabs MVC)
// Main layout — 720x560px panel centered at 1080p
// scriptclass "ViewBinding" enables auto-binding
// Relay_Command routes button clicks to controller methods
// =========================================================
FrameWidgetClass SorterRoot {
	size 1 1
	hexactpos 0
	vexactpos 0
	hexactsize 0
	vexactsize 0
	visible 0
	scriptclass "LFPG_SorterView"
	{
		// ── Modal overlay (fullscreen, click-to-close) ──
		ImageWidgetClass ModalOverlay {
			position 0 0
			size 1 1
			hexactpos 0
			vexactpos 0
			hexactsize 0
			vexactsize 0
			stretch 1
			color 0 0 0 0.65
		}

		// ── Main panel (centered) ──
		FrameWidgetClass SorterPanel {
			halign center_ref
			valign center_ref
			position 0 0
			size 720 560
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			{
				// Panel background
				ImageWidgetClass PanelBg {
					position 0 0
					size 720 560
					hexactpos 1
					vexactpos 1
					hexactsize 1
					vexactsize 1
					stretch 1
					ignorepointer 1
				}

				// Accent line (top, 2px)
				ImageWidgetClass AccentLine {
					position 0 0
					size 720 2
					hexactpos 1
					vexactpos 1
					hexactsize 1
					vexactsize 1
					stretch 1
					ignorepointer 1
				}

				// ════════════════════════════════
				// HEADER (y=2, h=42)
				// ════════════════════════════════
				FrameWidgetClass HeaderFrame {
