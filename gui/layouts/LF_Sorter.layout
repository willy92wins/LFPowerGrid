// =========================================================
// LF_PowerGrid — Sorter UI v2.0 (Dabs MVC)
// Main layout — 720x590px panel centered at 1080p
// scriptclass "ViewBinding" enables auto-binding
//
// BUTTON DISPATCH: Ningún ButtonWidgetClass tiene Relay_Command.
// Esto es INTENCIONAL (v2.7 fix): Relay_Command combinado con
// OnClick override causaba double-fire. Todo el dispatch se hace
// manualmente en LFPG_SorterView.OnClick() por nombre de botón.
// El único Relay_Command está en LF_SorterTag.layout (BtnRemove),
// que funciona porque TagView tiene ScriptView propio.
// =========================================================
FrameWidgetClass SorterRoot {
	size 1 1
	hexactpos 0
	vexactpos 0
	hexactsize 0
	vexactsize 0
	visible 0
	ignorepointer 1
	// L2 fix: scriptclass removed — ScriptView creates controller via GetControllerType()
	// Having scriptclass on root caused Workbench to spawn a second ViewController
	{
		// v2.7+: ClickBlocker eliminado. ChangeGameFocus(1) + SetDisabled(true)
		// previenen todo click-through. El widget con ignorepointer 1 no aportaba.
		// ── Main panel (centered programmatically, drag via SetPos) ──
		FrameWidgetClass SorterPanel {
			halign left_ref
			valign top_ref
			position 0 0
			size 720 590
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			clipchildren 1
			{
				// Panel background
				ImageWidgetClass PanelBg {
					position 0 0
					size 720 590
					hexactpos 1
					vexactpos 1
					hexactsize 1
					vexactsize 1
					stretch 1
					ignorepointer 1
					{
					}
				}

				// Panel side borders (P-I)
				ImageWidgetClass PanelBorderLeft {
					position 0 0
					size 1 590
					hexactpos 1
					vexactpos 1
					hexactsize 1
					vexactsize 1
					stretch 1
					ignorepointer 1
					{
					}
				}
				ImageWidgetClass PanelBorderRight {
					position 719 0
					size 1 590
					hexactpos 1
					vexactpos 1
					hexactsize 1
					vexactsize 1
					stretch 1
					ignorepointer 1
					{
					}
				}

				// Accent line (top, 2px)
				ImageWidgetClass AccentLine {
					position 0 0
					size 720 2
					hexactpos 1
					vexactpos 1
					hexactsize 1
					vexactsize 1
					stretch 1
					ignorepointer 1
					{
					}
				}

				// ════════════════════════════════
				// HEADER (y=2, h=42)
				// ════════════════════════════════
