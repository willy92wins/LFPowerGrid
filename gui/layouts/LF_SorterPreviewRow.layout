// =========================================================
// LF_PowerGrid — Sorter Preview Row prefab (Dabs MVC)
// Used as item in ObservableCollection<ref LFPG_SorterPreviewRow>
// Renders inside GridSpacerWidget "PreviewItems"
// =========================================================
FrameWidgetClass PreviewRowRoot {
	size 1 30
	hexactpos 0
	vexactpos 0
	hexactsize 0
	vexactsize 1
	scriptclass "LFPG_SorterPreviewRow"
	{
		ImageWidgetClass RowSep {
			position 0 29
			size 1 1
			hexactpos 0
			vexactpos 1
			hexactsize 0
			vexactsize 1
			stretch 1
			ignorepointer 1
			{
			}
		}
		ImageWidgetClass CatBadge {
			position 10 4
			size 22 22
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			stretch 1
			ignorepointer 1
			{
			}
		}
		TextWidgetClass CatIcon {
			scriptclass "ViewBinding"
			position 10 4
			size 22 22
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/Metron"
			"text halign" center
			"text valign" center
			ignorepointer 1
			{
			}
		}
		TextWidgetClass ItemName {
			scriptclass "ViewBinding"
			position 40 0
			size 210 30
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/MetronBook"
			"text valign" center
			ignorepointer 1
			{
			}
		}
		ImageWidgetClass SlotBadgeBg {
			position 258 6
			size 40 18
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			stretch 1
			ignorepointer 1
			{
			}
		}
		TextWidgetClass SlotText {
			scriptclass "ViewBinding"
			position 258 6
			size 40 18
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/Metron"
			"text halign" center
			"text valign" center
			ignorepointer 1
			{
			}
		}
	}
}
