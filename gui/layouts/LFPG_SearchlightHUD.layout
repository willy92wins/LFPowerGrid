FrameWidgetClass SearchlightHUDRoot {
	size 1 1
	hexactpos 0
	vexactpos 0
	hexactsize 0
	vexactsize 0
	visible 0
	ignorepointer 1
	{
		TextWidgetClass AimText {
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/MetronBook"
			ignorepointer 1
		}
		TextWidgetClass HintText {
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/MetronBook"
			ignorepointer 1
		}
		TextWidgetClass Crosshair {
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/MetronBook"
			ignorepointer 1
		}
	}
}
