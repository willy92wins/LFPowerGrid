FrameWidgetClass CCTVMenuRoot {
	size 1 1
	hexactpos 0
	vexactpos 0
	hexactsize 0
	vexactsize 0
	visible 0
	ignorepointer 1
	{
		ImageWidgetClass GreyOverlay {
			size 1 1
			hexactpos 0
			vexactpos 0
			hexactsize 0
			vexactsize 0
			stretch 1
			ignorepointer 1
		}
		CanvasWidgetClass ScanlineCanvas {
			size 1 1
			hexactpos 0
			vexactpos 0
			hexactsize 0
			vexactsize 0
			ignorepointer 1
		}
		TextWidgetClass CamLabel {
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/MetronBook"
			ignorepointer 1
		}
		TextWidgetClass RecLabel {
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/MetronBook"
			ignorepointer 1
		}
		TextWidgetClass TimestampLabel {
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/MetronBook"
			ignorepointer 1
		}
	}
}
