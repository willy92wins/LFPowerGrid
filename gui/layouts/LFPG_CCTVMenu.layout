FrameWidgetClass CCTVMenuRoot {
	size 1 1
	hexactpos 0
	vexactpos 0
	hexactsize 0
	vexactsize 0
	visible 0
	ignorepointer 1
	{
		TextWidgetClass CamLabel {
			position 16 12
			size 400 30
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/MetronBook"
			ignorepointer 1
		}
		TextWidgetClass RecLabel {
			halign right_ref
			position -80 12
			size 60 30
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/MetronBook"
			ignorepointer 1
		}
		TextWidgetClass TimestampLabel {
			valign bottom_ref
			position 16 -40
			size 300 26
			hexactpos 1
			vexactpos 1
			hexactsize 1
			vexactsize 1
			font "gui/fonts/MetronBook"
			ignorepointer 1
		}
	}
}
