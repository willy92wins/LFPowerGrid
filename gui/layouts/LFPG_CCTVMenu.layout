FrameWidgetClass CCTVMenuRoot {
	visible 0
	ignorepointer 1
	position 0 0
	size 1 1
	hexactpos 0
	hexactsize 0
	vexactpos 0
	vexactsize 0
	{
		TextWidgetClass CamLabel {
			visible 1
			ignorepointer 1
			position 16 12
			hexactpos 1
			vexactpos 1
			text "CAM-000000  [1/1]"
			color "200 40 220 40"
			size 400 30
			hexactsize 1
			vexactsize 1
		}
		TextWidgetClass RecLabel {
			visible 1
			ignorepointer 1
			halign right_ref
			position -80 12
			hexactpos 1
			vexactpos 1
			text "REC"
			color "220 220 30 30"
			size 60 30
			hexactsize 1
			vexactsize 1
		}
		TextWidgetClass TimestampLabel {
			visible 1
			ignorepointer 1
			valign bottom_ref
			position 16 -12
			hexactpos 1
			vexactpos 1
			text "0000-00-00  00:00"
			color "180 40 200 40"
			size 300 26
			hexactsize 1
			vexactsize 1
		}
	}
}
